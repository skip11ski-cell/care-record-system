# LINE Developers の Messaging API チャネルで取得
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# クラウド本番では PostgreSQL の URL を設定（Render / Railway / Supabase 等が発行）
# 未設定のときは SQLite（care_records.db）。コンテナのみで SQLite は再起動で消えるため本番は PostgreSQL 推奨
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# 開発用: ngrok 等の HTTPS URL のパスに合わせる（例: https://xxxx.ngrok-free.app/callback）
# アプリは 0.0.0.0:8000 で待ち受け
APP_PUBLIC_BASE_URL=

# true のとき署名検証をスキップ（ローカルで curl テストする場合のみ。本番では false）
DEV_SKIP_LINE_SIGNATURE=false

# Google AI Studio 等で発行（任意）。未設定なら AI 整形は行わず原文のまま保存
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
